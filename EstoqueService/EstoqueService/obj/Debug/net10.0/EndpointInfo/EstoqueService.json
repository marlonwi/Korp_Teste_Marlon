      "post": {
        "tags": [
          "Produtos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Produto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Produto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Produto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Produtos"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/produtos/estoque/baixar-lote": {
      "post": {
        "tags": [
          "Produtos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BaixaEstoqueRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BaixaEstoqueRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BaixaEstoqueRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BaixaEstoqueRequest": {
        "type": "object",
        "properties": {
          "itens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemBaixaRequest"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ItemBaixaRequest": {
        "type": "object",
        "properties": {
          "produtoId": {
            "type": "integer",
            "format": "int32"
          },
          "quantidade": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Produto": {
        "required": [
          "descricao"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "descricao": {
            "type": "string",
            "nullable": true
          },
          "saldo": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Produtos"
    }
  ]
}